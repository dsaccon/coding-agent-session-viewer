Screen {
    layout: horizontal;
}

#projects-panel {
    width: 1fr;
    min-width: 20;
    border-right: solid $surface-lighten-2;
}

#sessions-panel {
    width: 1fr;
    min-width: 25;
    border-right: solid $surface-lighten-2;
}

#conversation-panel {
    width: 2fr;
}

.panel-header {
    dock: top;
    height: 1;
    background: $surface-darken-1;
    color: $text-muted;
    text-style: bold;
    padding: 0 1;
    text-align: center;
}

.active-header {
    background: $primary;
    color: $text;
}

#status-bar {
    dock: bottom;
    height: 1;
    background: $primary-darken-2;
    color: $text-muted;
    padding: 0 1;
}

ListView {
    background: $surface;
}

ListView > ListItem {
    padding: 0 1;
    margin-bottom: 1;
}

ListView > ListItem.--highlight {
    background: $primary-darken-1;
}

#conversation-scroll {
    background: $surface;
}

.user-header {
    color: $success;
    text-style: bold;
    background: $surface-lighten-1;
    padding: 1 0 0 1;
    margin: 1 0 0 0;
    width: 1fr;
}

.user-text {
    background: $surface-lighten-1;
    padding: 0 0 1 3;
    width: 1fr;
}

.assistant-header {
    color: #d4a0ff;
    text-style: bold;
    padding: 1 0 0 1;
    margin: 1 0 0 0;
    width: 1fr;
}

.assistant-text {
    padding: 0 0 0 3;
    width: 1fr;
}

Markdown.assistant-text {
    margin: 0;
    padding: 0 0 0 3;
}

Markdown.assistant-text MarkdownFence {
    margin: 1 0;
    max-height: 30;
    overflow-y: auto;
}

.tool-header {
    color: $warning;
}

.timestamp {
    color: $text-muted;
}

.session-time-row {
    height: 1;
    width: 1fr;
}

#sessions-list ListItem {
    height: auto;
    max-height: 4;
}

#sessions-list ListItem Vertical {
    height: auto;
}

.session-start {
    color: $primary-lighten-2;
    width: 1fr;
}

.session-end {
    color: $text-muted;
    text-align: right;
    width: auto;
}

.select-cursor {
    border-left: thick $warning;
}

.select-marked {
    background: $primary-darken-2;
}

.select-cursor.select-marked {
    border-left: thick $warning;
    background: $primary-darken-2;
}
