Screen {
    layout: horizontal;
}

#projects-panel {
    width: 1fr;
    min-width: 20;
    border-right: solid $surface-lighten-2;
}

#sessions-panel {
    width: 1fr;
    min-width: 25;
    border-right: solid $surface-lighten-2;
}

#conversation-panel {
    width: 2fr;
}

.panel-header {
    dock: top;
    height: 1;
    background: $primary-darken-2;
    color: $text;
    text-style: bold;
    padding: 0 1;
    text-align: center;
}

#status-bar {
    dock: bottom;
    height: 1;
    background: $primary-darken-2;
    color: $text-muted;
    padding: 0 1;
}

ListView {
    background: $surface;
}

ListView > ListItem {
    padding: 0 1;
    border-bottom: solid $surface-lighten-3;
}

ListView > ListItem.--highlight {
    background: $primary-darken-1;
    padding: 0 1 1 1;
    border-bottom: none;
}

#conversation-scroll {
    background: $surface;
}

.user-header {
    color: $success;
    text-style: bold;
    background: $surface-lighten-1;
    padding: 1 0 0 1;
    margin: 1 0 0 0;
    width: 1fr;
}

.user-text {
    background: $surface-lighten-1;
    padding: 0 0 1 3;
    width: 1fr;
}

.assistant-header {
    color: #d4a0ff;
    text-style: bold;
    padding: 1 0 0 1;
    margin: 1 0 0 0;
    width: 1fr;
}

.assistant-text {
    padding: 0 0 0 3;
    width: 1fr;
}

.tool-header {
    color: $warning;
}

.timestamp {
    color: $text-muted;
}

.session-time {
    color: $primary-lighten-2;
}

.session-end-time {
    color: $text-muted;
}

.session-preview {
    color: $text;
}
